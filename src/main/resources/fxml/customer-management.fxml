<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mes.controller.CustomerController"
      spacing="15"
      style="-fx-background-color: #1e1e1e; -fx-padding: 10;">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label styleClass="content-header" text="客户管理"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addButton" styleClass="action-button, add-button" text="➕ 新增" onAction="#showAddDialog"/>
        <Button fx:id="editButton" styleClass="action-button, edit-button" text="✏️ 修改" onAction="#handleBatchEdit"/>
        <Button fx:id="deleteButton" styleClass="action-button, delete-button" text="🗑️ 删除" onAction="#handleBatchDelete"/>
        <Button fx:id="exportButton" styleClass="action-button" text="📤 导出" onAction="#handleExport"
                style="-fx-background-color: #17a2b8; -fx-text-fill: white;"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #252526; -fx-background-radius: 8; -fx-padding: 15;">
        <Label text="客户编码:" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="codeSearchField" promptText="请输入客户编码" styleClass="input-field" prefWidth="120"/>
        <Label text="客户名称:" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="nameSearchField" promptText="请输入客户名称" styleClass="input-field" prefWidth="120"/>
        <Label text="是否启用:" style="-fx-text-fill: #cccccc;"/>
        <ComboBox fx:id="enabledSearchCombo" styleClass="input-field" prefWidth="120"/>
        <Button styleClass="action-button" text="🔍 查询" onAction="#handleSearch"
                style="-fx-background-color: #007acc; -fx-text-fill: white;"/>
        <Button styleClass="action-button" text="🔄 重置" onAction="#handleReset"
                style="-fx-background-color: #6c757d; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="selectColumn" text="选择" prefWidth="50">
            </TableColumn>
            <TableColumn fx:id="codeColumn" text="客户编码" prefWidth="100">
            </TableColumn>
            <TableColumn fx:id="nameColumn" text="客户名称" prefWidth="120">
            </TableColumn>
            <TableColumn fx:id="contactColumn" text="联系人" prefWidth="80">
            </TableColumn>
            <TableColumn fx:id="phoneColumn" text="联系电话" prefWidth="120">
            </TableColumn>
            <TableColumn fx:id="emailColumn" text="邮箱" prefWidth="150">
            </TableColumn>
            <TableColumn fx:id="addressColumn" text="地址" prefWidth="200">
            </TableColumn>
            <TableColumn fx:id="enabledColumn" text="是否启用" prefWidth="80">
            </TableColumn>
            <TableColumn fx:id="actionColumn" text="操作" prefWidth="120">
            </TableColumn>
        </columns>
    </TableView>
</VBox>
