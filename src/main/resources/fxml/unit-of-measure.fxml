<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mes.controller.UnitOfMeasureController"
      spacing="15">

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label styleClass="content-header" text="计量单位"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addButton" styleClass="action-button, add-button" text="➕ 新增" onAction="#showAddDialog"/>
        <Button fx:id="editButton" styleClass="action-button, edit-button" text="✏️ 修改" onAction="#handleBatchEdit"/>
        <Button fx:id="deleteButton" styleClass="action-button, delete-button" text="🗑️ 删除" onAction="#handleBatchDelete"/>
        <Button fx:id="exportButton" styleClass="action-button" text="📤 导出" onAction="#handleExport" 
                style="-fx-background-color: #17a2b8; -fx-text-fill: white;"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #252526; -fx-background-radius: 8; -fx-padding: 15;">
        <Label text="单位编码:" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="codeSearchField" promptText="请输入单位编码" styleClass="input-field" prefWidth="150"/>
        <Label text="单位名称:" style="-fx-text-fill: #cccccc;"/>
        <TextField fx:id="nameSearchField" promptText="请输入单位名称" styleClass="input-field" prefWidth="150"/>
        <Button styleClass="action-button" text="🔍 查询" onAction="#handleSearch" 
                style="-fx-background-color: #007acc; -fx-text-fill: white;"/>
        <Button styleClass="action-button" text="🔄 重置" onAction="#handleReset"
                style="-fx-background-color: #6c757d; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="unitTable" prefHeight="500">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60">
            </TableColumn>
            <TableColumn fx:id="codeColumn" text="单位编码" prefWidth="120">
            </TableColumn>
            <TableColumn fx:id="nameColumn" text="单位名称" prefWidth="120">
            </TableColumn>
            <TableColumn fx:id="descriptionColumn" text="描述" prefWidth="200">
            </TableColumn>
            <TableColumn fx:id="baseUnitColumn" text="启用主单位" prefWidth="100">
            </TableColumn>
            <TableColumn fx:id="enabledColumn" text="是否启用" prefWidth="100">
            </TableColumn>
            <TableColumn fx:id="actionColumn" text="操作" prefWidth="150">
            </TableColumn>
        </columns>
    </TableView>
</VBox>
