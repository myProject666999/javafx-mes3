<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mes.controller.MainController"
            stylesheets="/css/style.css"
            styleClass="root">

    <top>
        <HBox style="-fx-background-color: #323233;" alignment="CENTER_LEFT">
            <padding>
                <Insets top="4" right="8" bottom="4" left="8"/>
            </padding>

            <Label fx:id="titleLabel" text="MES System"
                   style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="0">
                <Button styleClass="window-button" text="─" onAction="#minimizeWindow"/>
                <Button fx:id="maximizeBtn" styleClass="window-button" text="□" onAction="#maximizeWindow"/>
                <Button styleClass="window-button, close-button" text="✕" onAction="#closeWindow"/>
            </HBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" prefWidth="200" spacing="0">
            <VBox fx:id="sidebarMenu" spacing="2">
                <padding>
                    <Insets top="10" bottom="5" left="0" right="0"/>
                </padding>
                <Button styleClass="sidebar-button, active" text="🏠  控制台" onAction="#showDashboard"/>
            </VBox>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" 
                       style="-fx-background-color: transparent; -fx-border-width: 0;"
                       VBox.vgrow="ALWAYS">
                <VBox spacing="2" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets top="5" bottom="5" left="0" right="0"/>
                    </padding>

                    <Label fx:id="systemMenuLabel" text="系统管理" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button fx:id="userMenuBtn" styleClass="sidebar-button" text="👥  用户管理" onAction="#showUserManagement"/>
                    <Button fx:id="roleMenuBtn" styleClass="sidebar-button" text="🎭  角色管理" onAction="#showRoleManagement"/>
                    <Button fx:id="permissionMenuBtn" styleClass="sidebar-button" text="🔑  权限管理" onAction="#showPermissionManagement"/>
                    
                    <Label fx:id="masterDataMenuLabel" text="主数据" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button fx:id="uomMenuBtn" styleClass="sidebar-button" text="📏  计量单位" onAction="#showUnitOfMeasure"/>
                    <Button fx:id="supplierMenuBtn" styleClass="sidebar-button" text="🏪  供应商设置" onAction="#showSupplierManagement"/>

                    <Label fx:id="productMenuLabel" text="产品管理" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button fx:id="productCategoryMenuBtn" styleClass="sidebar-button" text="📁  物料产品分类" onAction="#showProductCategory"/>
                    <Button fx:id="productManagementMenuBtn" styleClass="sidebar-button" text="📦  物料产品管理" onAction="#showProductManagement"/>

                    <Label fx:id="workshopMenuLabel" text="车间管理" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button fx:id="workshopMenuBtn" styleClass="sidebar-button" text="🏭  车间设置" onAction="#showWorkshop"/>
                    <Button fx:id="workstationMenuBtn" styleClass="sidebar-button" text="⚙️  工作站管理" onAction="#showWorkstation"/>

                    <Label fx:id="processMenuLabel" text="工艺管理" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button fx:id="processMenuBtn" styleClass="sidebar-button" text="🔧  工序设置" onAction="#showProcess"/>
                    <Button fx:id="processRouteMenuBtn" styleClass="sidebar-button" text="📋  工序流程" onAction="#showProcessRoute"/>

                    <Label fx:id="customerMenuLabel" text="客户管理" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button fx:id="customerMenuBtn" styleClass="sidebar-button" text="👥  客户管理" onAction="#showCustomerManagement"/>

                    <Label fx:id="personalMenuLabel" text="个人设置" style="-fx-text-fill: #888; -fx-font-size: 11px; -fx-padding: 10 15 5 15;"/>
                    <Button styleClass="sidebar-button" text="🔐  修改密码" onAction="#showChangePassword"/>
                </VBox>
            </ScrollPane>

            <VBox spacing="2">
                <Separator style="-fx-padding: 5 10;"/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <padding>
                        <Insets top="10" right="15" bottom="10" left="15"/>
                    </padding>
                    <Label fx:id="userInfoLabel" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;"/>
                </HBox>
                <Button styleClass="sidebar-button" text="🚪  退出登录" onAction="#logout"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-area">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <VBox fx:id="dashboardView" spacing="20">
                <Label styleClass="content-header" text="控制台"/>

                <GridPane hgap="20" vgap="20">
                    <VBox style="-fx-background-color: #252526; -fx-background-radius: 8; -fx-padding: 20;"
                          GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="👥 用户总数" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
                        <Label fx:id="userCountLabel" style="-fx-text-fill: #007acc; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox style="-fx-background-color: #252526; -fx-background-radius: 8; -fx-padding: 20;"
                          GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="🎭 角色总数" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
                        <Label fx:id="roleCountLabel" style="-fx-text-fill: #28a745; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox style="-fx-background-color: #252526; -fx-background-radius: 8; -fx-padding: 20;"
                          GridPane.columnIndex="2" GridPane.rowIndex="0">
                        <Label text="🔑 权限总数" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;"/>
                        <Label fx:id="permissionCountLabel" style="-fx-text-fill: #ffc107; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                    </VBox>
                </GridPane>

                <VBox spacing="10">
                    <Label text="当前用户权限" style="-fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <ListView fx:id="permissionListView" prefHeight="200"
                              style="-fx-background-color: #252526;"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
