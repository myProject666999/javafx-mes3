<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.mes.controller.ChangePasswordController"
      spacing="30"
      alignment="CENTER">

    <VBox styleClass="login-container"
          alignment="CENTER"
          spacing="25"
          maxWidth="450"
          maxHeight="400">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <Label styleClass="content-header" text="修改密码"/>

        <VBox spacing="15" prefWidth="350">
            <VBox spacing="5">
                <Label text="当前密码" style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>
                <PasswordField fx:id="oldPasswordField" styleClass="input-field" promptText="请输入当前密码"/>
            </VBox>

            <VBox spacing="5">
                <Label text="新密码" style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>
                <PasswordField fx:id="newPasswordField" styleClass="input-field" promptText="请输入新密码"/>
            </VBox>

            <VBox spacing="5">
                <Label text="确认新密码" style="-fx-text-fill: #cccccc; -fx-font-size: 13px;"/>
                <PasswordField fx:id="confirmPasswordField" styleClass="input-field" promptText="请再次输入新密码"/>
            </VBox>

            <Label fx:id="messageLabel" style="-fx-font-size: 12px;"/>

            <Button styleClass="login-button" text="确认修改"
                    prefHeight="40"
                    onAction="#handleChangePassword"/>
        </VBox>
    </VBox>
</VBox>
